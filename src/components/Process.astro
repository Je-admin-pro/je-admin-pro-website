---
import { methodSteps, deliverables } from "../config.ts";
---

<section id="process" class="bg-cream-dark py-20 lg:py-28">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">

    <!-- En-tête -->
    <div class="max-w-2xl mb-16 reveal" data-reveal="up">
      <p class="text-turquoise text-xs font-sans font-semibold tracking-[0.18em] uppercase mb-4">
        Ma méthode
      </p>
      <h2 class="font-display text-3xl lg:text-4xl text-marine leading-snug">
        Les étapes de mon accompagnement
      </h2>
    </div>

    <!-- Étapes -->
    <ol class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      {methodSteps.map((step, i) => (
        <li class="relative reveal flex flex-col gap-5" data-reveal="up" data-delay={i * 120}>

          <!-- Ligne vers l'étape suivante (desktop, sauf dernière) -->
          {i < methodSteps.length - 1 && (
            <div
              class="hidden lg:block absolute top-5 h-px bg-turquoise/25"
              style="left: 2.5rem; right: -2rem;"
              aria-hidden="true"
            ></div>
          )}

          <!-- Numéro -->
          <div class="relative z-10 w-10 h-10 rounded-full bg-turquoise flex items-center justify-center shrink-0">
            <span class="font-sans text-xs font-semibold text-cream">
              {String(i + 1).padStart(2, "0")}
            </span>
          </div>

          <!-- Contenu -->
          <div class="flex flex-col gap-2">
            <h3 class="font-display text-xl text-marine leading-snug">
              {step.title}
            </h3>
            <p class="font-sans text-sm text-muted leading-relaxed">
              {step.body}
            </p>
          </div>

        </li>
      ))}
    </ol>

    <!-- Livrables -->
    <div class="mt-14 reveal" data-reveal="up" data-delay={200}>
      <div class="bg-marine rounded-2xl px-8 py-10 lg:px-12 lg:py-12">
        <div class="flex flex-col gap-8">

          <!-- Label -->
          <div>
            <p class="text-turquoise-pale text-xs font-sans font-semibold tracking-[0.18em] uppercase mb-2">
              À l'issue de mon intervention
            </p>
            <h3 class="font-display text-2xl lg:text-3xl text-cream leading-snug">
              Vous repartez avec
            </h3>
          </div>

          <!-- Items -->
          <ul class="grid sm:grid-cols-2 gap-4">
            {deliverables.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full bg-turquoise/20 flex items-center justify-center text-turquoise-pale">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span class="font-sans text-sm text-cream/80 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>

        </div>
      </div>
    </div>

  </div>
</section>
