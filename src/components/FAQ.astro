---
import { faq } from "../config.ts";
---

<section id="faq" class="bg-cream py-20 lg:py-28">
  <div class="max-w-3xl mx-auto px-6 lg:px-8">

    <!-- En-tête -->
    <div class="mb-12 reveal" data-reveal="up">
      <p class="text-turquoise text-xs font-sans font-semibold tracking-[0.18em] uppercase mb-4">
        Questions fréquentes
      </p>
      <h2 class="font-display text-3xl lg:text-4xl text-marine leading-snug">
        Vous avez des questions ?
      </h2>
    </div>

    <!-- Accordéon -->
    <div class="flex flex-col divide-y divide-cream-dark">
      {faq.map((item, i) => (
        <details
          class="group reveal"
          data-reveal="up"
          data-delay={i * 80}
        >
          <summary class="flex items-center justify-between gap-6 py-5 cursor-pointer list-none">
            <span class="font-sans font-medium text-marine text-base pr-2">
              {item.question}
            </span>
            <span class="shrink-0 w-6 h-6 rounded-full border border-turquoise/30 flex items-center justify-center text-turquoise transition-transform duration-300 group-open:rotate-45">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </span>
          </summary>
          <div class="pb-6 font-sans text-sm text-muted leading-relaxed">
            {item.answer}
          </div>
        </details>
      ))}
    </div>

  </div>
</section>
