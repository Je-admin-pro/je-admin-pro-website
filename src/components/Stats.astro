---
import { stats } from "../config.ts";
---

<section class="bg-cream py-20 lg:py-24 border-t border-cream-dark">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <p
      class="text-turquoise text-xs font-sans font-semibold tracking-[0.18em] uppercase mb-14 reveal"
      data-reveal="up"
    >
      Des chiffres parlants
    </p>

    <ul
      class="grid md:grid-cols-3 gap-px bg-cream-dark rounded-2xl overflow-hidden"
    >
      {
        stats.map((stat, i) => (
          <li
            class="reveal bg-cream px-8 py-10 flex flex-col gap-4"
            data-reveal="up"
            data-delay={i * 120}
          >
            <div class="font-display text-6xl lg:text-7xl font-semibold text-marine leading-none">
              <span data-counter={stat.value} data-suffix={stat.suffix}>
                0
              </span>
            </div>
            <p class="text-muted text-sm leading-relaxed max-w-[22ch]">
              {stat.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
