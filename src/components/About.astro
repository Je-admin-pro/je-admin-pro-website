---
import { site } from "../config.ts";
---

<section id="apropos" class="bg-marine py-20 lg:py-28">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Texte (gauche sur desktop) -->
      <div class="order-1 flex flex-col gap-8 reveal" data-reveal="left">

        <div>
          <p class="text-turquoise-pale text-xs font-sans font-semibold tracking-[0.18em] uppercase mb-4">
            Qui suis-je ?
          </p>
          <h2 class="font-display text-3xl lg:text-4xl text-cream leading-snug">
            {site.name}
          </h2>
          <p class="text-cream/50 font-sans text-sm mt-1">{site.role}</p>
        </div>

        <div class="w-12 h-px bg-turquoise-pale/40"></div>

        <div class="flex flex-col gap-5 text-cream/80 font-sans text-sm leading-relaxed">
          <p>
            J'accompagne les dirigeants de TPE/PME dans la restauration débordés
            par leur gestion administrative à reprendre le contrôle de leur
            organisation.
          </p>
          <p>
            Forte de <strong class="text-cream font-semibold">18 ans d'expertise</strong>,
            je transforme le chaos administratif en processus fluides et structurés.
          </p>
          <p>
            Je sécurise votre gestion et libère votre charge mentale pour vous
            redonner une totale sérénité de pilotage.
          </p>
        </div>

      </div>

      <!-- Photo (droite sur desktop) -->
      <div class="relative order-2 reveal" data-reveal="right">
        <div class="absolute -top-5 -left-5 w-full h-full rounded-2xl bg-turquoise/10 hidden md:block"></div>
        <div class="relative aspect-video md:aspect-[4/5] rounded-2xl overflow-hidden bg-white/5">
          <!-- TODO: <Image src={import("../assets/julie.webp")} alt="Julie Etienne" class="w-full h-full object-cover" /> -->
          <div class="w-full h-full flex items-end p-6">
            <span class="text-xs text-cream/30 font-sans">Photo à venir</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
