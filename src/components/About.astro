---
import { site } from "../config.ts";
import julie from "../assets/julie.png";
import { Image } from "astro:assets";
---

<section id="apropos" class="bg-marine py-20 lg:py-28">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Texte (gauche sur desktop) -->
      <div class="order-1 flex flex-col gap-8 reveal" data-reveal="left">
        <div>
          <p
            class="text-turquoise-pale text-xs font-sans font-semibold tracking-[0.18em] uppercase mb-4"
          >
            Qui suis-je ?
          </p>
          <h2 class="font-display text-3xl lg:text-4xl text-cream leading-snug">
            {site.name}
          </h2>
          <p class="text-cream/50 font-sans text-sm mt-1">{site.role}</p>
        </div>

        <div class="w-12 h-px bg-turquoise-pale/40"></div>

        <div
          class="flex flex-col gap-5 text-cream/80 font-sans text-sm leading-relaxed"
        >
          <p>
            J'accompagne les dirigeants de TPE/PME dans la restauration débordés
            par leur gestion administrative à reprendre le contrôle de leur
            organisation.
          </p>
          <p>
            Forte de <strong class="text-cream font-semibold"
              >18 ans d'expertise</strong
            >, je transforme le chaos administratif en processus fluides et
            structurés.
          </p>
          <p>
            Je sécurise votre gestion et libère votre charge mentale pour vous
            redonner une totale sérénité de pilotage.
          </p>
        </div>
      </div>

      <!-- Photo (droite sur desktop) -->
      <div
        class="relative order-2 flex justify-center items-end reveal"
        data-reveal="right"
      >
        <div
          class="absolute bottom-0 left-1/2 -translate-x-1/2 w-64 h-64 rounded-full bg-turquoise/10 blur-3xl"
        >
        </div>
        <Image
          src={julie}
          alt="Julie Etienne"
          class="relative w-full max-w-sm object-contain"
        />
      </div>
    </div>
  </div>
</section>
