---
import { site, navLinks } from "../config.ts";

const year = new Date().getFullYear();
const isHome = Astro.url.pathname === "/";
const linkHref = (href: string) => (isHome ? href : `/${href}`);
---

<footer class="bg-cream border-t border-cream-dark">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-8">
    <div
      class="flex flex-col sm:flex-row sm:items-center justify-between gap-6"
    >
      <!-- Gauche : identité -->
      <div class="flex flex-col gap-0.5">
        <span class="font-display text-sm text-marine">{site.name}</span>
        <span class="font-sans text-xs text-muted-light"
          >{site.role} - {site.city}</span
        >
      </div>

      <!-- Centre : nav -->
      <nav aria-label="Navigation" class="flex flex-wrap gap-x-6 gap-y-2">
        {
          navLinks.map((link) => (
            <a
              href={linkHref(link.href)}
              class="inline-flex items-center min-h-6 font-sans text-xs text-muted hover:text-turquoise transition-colors duration-200"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Droite : contact -->
      <div class="flex flex-col gap-0.5 sm:items-end">
        <a
          href={`mailto:${site.email}`}
          class="inline-flex items-center min-h-6 py-1 font-sans text-xs text-muted hover:text-turquoise transition-colors duration-200"
        >
          {site.email}
        </a>
        <a
          href={`tel:${site.phone.replace(/\s/g, "")}`}
          class="inline-flex items-center min-h-6 py-1 font-sans text-xs text-muted hover:text-turquoise transition-colors duration-200"
        >
          {site.phone}
        </a>
        <a
          href="https://www.linkedin.com/in/julie-%C3%A9tienne-162758112/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="inline-flex items-center justify-center min-h-6 min-w-6 p-1 -m-1 text-muted hover:text-turquoise transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bas : copyright + légal -->
    <div
      class="mt-6 pt-5 border-t border-cream-dark flex flex-col sm:flex-row items-center justify-between gap-2"
    >
      <p class="font-sans text-[11px] text-muted-light">
        &copy; {year}
        {site.name}
      </p>
      <div class="flex gap-4">
        <a
          href="/mentions-legales"
          class="inline-flex items-center min-h-6 font-sans text-[11px] text-muted-light hover:text-turquoise transition-colors duration-200"
        >
          Mentions légales
        </a>
        <a
          href="/politique-de-confidentialite"
          class="inline-flex items-center min-h-6 font-sans text-[11px] text-muted-light hover:text-turquoise transition-colors duration-200"
        >
          Politique de confidentialité
        </a>
      </div>
    </div>
  </div>
</footer>
