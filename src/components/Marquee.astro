---
interface Props {
  items: readonly string[];
  reverse?: boolean;
  speed?: number;
  class?: string;
}

const { items, reverse = false, speed = 35, class: className = "" } = Astro.props;
---

<div class:list={["overflow-hidden", className]}>
  <ul
    class:list={["marquee", { "marquee-reverse": reverse }]}
    style={`--marquee-speed: ${speed}s`}
    aria-hidden="true"
  >
    {[...items, ...items, ...items, ...items].map((item) => (
      <li class="flex items-center gap-6 pr-6 shrink-0">
        <span class="whitespace-nowrap">{item}</span>
        <span class="w-1.5 h-1.5 rounded-full bg-current opacity-40 shrink-0"></span>
      </li>
    ))}
  </ul>
</div>
